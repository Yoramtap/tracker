{
  "name": "tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 4173",
    "lint": "eslint . --ext .js,.mjs",
    "lint:fix": "eslint . --ext .js,.mjs --fix",
    "format": "prettier \"**/*.{js,mjs,css,html,json}\" --write",
    "format:check": "prettier \"**/*.{js,mjs,css,html,json}\" --check",
    "auth:setup": "node scripts/dev/setup-backlog-auth.mjs",
    "data:refresh": "node scripts/refresh-report-data.mjs",
    "data:refresh:clean": "node scripts/refresh-report-data.mjs --clean",
    "data:validate": "node scripts/validate-dashboard-snapshots.mjs",
    "build": "node scripts/export-public.mjs --target dist",
    "dev:refresh:stage": "node scripts/refresh-report-data.mjs",
    "dev:refresh:pr-cycle": "PR_CYCLE_ONLY=true node scripts/refresh-report-data.mjs",
    "dev:refresh:pr-activity": "PR_ACTIVITY_ONLY=true SKIP_TREND_REFRESH=true node scripts/refresh-report-data.mjs",
    "dev:refresh:product-cycle": "PRODUCT_CYCLE_ONLY=true node scripts/refresh-report-data.mjs",
    "dev:refresh:uat": "UAT_ONLY=true SKIP_UAT_AGING=true node scripts/refresh-report-data.mjs",
    "dev:bench:refresh": "node scripts/dev/benchmark-refresh-phases.mjs",
    "dev:bench:dashboard": "node scripts/dev/benchmark-dashboard-assets.mjs",
    "dev:analyze": "node scripts/dev/analyze-report-data.mjs --output .cache/analysis/latest-analysis.md",
    "dev:smoke": "node scripts/dev/smoke-dashboard.mjs",
    "dev:smoke:render": "node scripts/dev/smoke-dashboard-render.mjs",
    "dev:publish": "node scripts/dev/publish-tracker.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.20.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.0"
  },
  "dependencies": {
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "agentation": "^3.0.2"
  }
}
