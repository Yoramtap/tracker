{
  "name": "bugtracker-workshop",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 4173",
    "dev:workshop": "python3 -m http.server 4173",
    "dev:tracker": "python3 -m http.server 4173 --directory /Users/yoramtap/Documents/AI/tracker",
    "lint": "eslint . --ext .js,.mjs",
    "lint:fix": "eslint . --ext .js,.mjs --fix",
    "format": "prettier \"**/*.{js,mjs,css,html,json}\" --write",
    "format:check": "prettier \"**/*.{js,mjs,css,html,json}\" --check",
    "refresh:full": "node scripts/refresh-report-data.mjs",
    "refresh:pr-cycle": "PR_CYCLE_ONLY=true node scripts/refresh-report-data.mjs",
    "analyze:brief": "node scripts/analyze-report-data.mjs --output reports/latest-analysis.md",
    "backlog:setup-auth": "node scripts/setup-backlog-auth.mjs",
    "export:public": "node scripts/export-public.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.0"
  },
  "dependencies": {
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "agentation": "^2.3.3"
  }
}
